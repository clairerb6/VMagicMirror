<UserControl x:Class="Baku.VMagicMirrorConfig.View.EffectSettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:view="clr-namespace:Baku.VMagicMirrorConfig.View"
             xmlns:vm="clr-namespace:Baku.VMagicMirrorConfig.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="2050"
             d:DesignWidth="450"
             >
    <UserControl.DataContext>
        <vm:EffectSettingViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <view:WhiteSpaceStringToNullConverter x:Key="WhiteSpaceStringToNullConverter"/>
        <view:AntiAliasStyleToTextConverter x:Key="AntiAliasStyleToTextConverter"/>
        <view:AvailableFramerateToTextConverter x:Key="AvailableFramerateToTextConverter"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="20,5"/>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  >
        <StackPanel>

            <TextBlock 
                Text="{DynamicResource Effect_Header}"                 
                Style="{StaticResource SectionHeaderText}"
                />
            
            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="5">

                        <md:PackIcon Kind="Monitors"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource ImageQuality}"
                                   Style="{StaticResource HeaderText}"
                                   Margin="5"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetImageQualitySettingCommand}"
                                />
                    </StackPanel>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource ImageQuality_CurrentQuality}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  Margin="5"
                                  ItemsSource="{Binding ImageQualityNames}"
                                  SelectedItem="{Binding ImageQuality.Value, Converter={StaticResource WhiteSpaceStringToNullConverter}}"
                                  md:HintAssist.Hint="Quality"
                                  />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource ImageQuality_AntiAlias}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  Margin="5"
                                  ItemsSource="{Binding AvailableAntiAliasStyle}"
                                  SelectedItem="{Binding AntiAliasStyle.Value}"
                                  md:HintAssist.Hint="Choose..."
                                  >
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path={}, Converter={StaticResource AntiAliasStyleToTextConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource ImageQuality_Framerate}"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  Margin="5"
                                  ItemsSource="{Binding AvailableTargetFramerateStyle}"
                                  SelectedItem="{Binding TargetFramerateStyle.Value}"
                                  >
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path={}, Converter={StaticResource AvailableFramerateToTextConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <CheckBox Margin="10,5"
                              Content="{DynamicResource ImageQuality_UseBoneFrameReduction}"
                              IsChecked="{Binding UseFrameReductionEffect.Value}"
                              />

                    <CheckBox Margin="10,5"
                              Content="{DynamicResource ImageQuality_DisableHdrAlways}"
                              IsChecked="{Binding DisableHdrAlways.Value}"
                              />

                    <TextBlock Margin="25,0,25,15" 
                               TextWrapping="Wrap"
                               Text="{DynamicResource ImageQuality_DisableHdrAlways_Notice}"
                        />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>

                    <StackPanel Orientation="Horizontal">

                        <md:PackIcon Style="{StaticResource SettingHeaderPackIcon}"
                                     Kind="LightbulbOn"
                                     />

                        <TextBlock Text="{DynamicResource Light}"
                                   Margin="5"
                                   Style="{StaticResource HeaderText}"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetLightSettingCommand}"
                                />

                    </StackPanel>

                    <Grid Margin="5">
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource Light_Color}" />

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Rectangle Style="{StaticResource ColorSampleRectangle}">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{Binding LightColor}"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Style="{DynamicResource ColorEditButton}"
                                    Command="{Binding EditLightColorCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Style="{StaticResource ColorEditButtonIcon}"/>
                                    <TextBlock Style="{StaticResource ColorEditButtonText}"
                                               Text="{DynamicResource Setting_EditColor}"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>


                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource Light_Intensity}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderLightIntensity"
                                Minimum="0"
                                Maximum="500"
                                Value="{Binding LightIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderLightIntensity}"
                                 />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource Light_Yaw}" />
                        <Slider Grid.Row="2" Grid.Column="1"
                                x:Name="sliderLightYaw"
                                Minimum="-180"
                                Maximum="180"
                                Value="{Binding LightYaw.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderLightYaw}"
                                 />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{DynamicResource Light_Pitch}" />
                        <Slider Grid.Row="3" Grid.Column="1"
                                x:Name="sliderLightPitch"
                                Minimum="-90"
                                Maximum="90"
                                Value="{Binding LightPitch.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="3" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderLightPitch}"
                                 />

                    </Grid>

                    <CheckBox Content="{DynamicResource Light_BgAdjust}"
                              Margin="15,5"
                              IsChecked="{Binding UseDesktopLightAdjust.Value}"
                              />

                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="5">

                        <md:PackIcon Kind="BoxShadow"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource Shadow}"
                                   Style="{StaticResource HeaderText}"
                                   Margin="5"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetShadowSettingCommand}"
                                />
                    </StackPanel>

                    <CheckBox Margin="10,5,10,10"
                              Content="{DynamicResource Shadow_Enable}"
                              IsChecked="{Binding EnableShadow.Value}"
                              />

                    <Grid Margin="5"
                          IsEnabled="{Binding EnableShadow.Value}"
                          >
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource Shadow_Intensity}" />
                        <Slider Grid.Row="0" Grid.Column="1"
                                x:Name="sliderShadowIntensity"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding ShadowIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderShadowIntensity}"
                                 />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource Shadow_Yaw}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderShadowYaw"
                                Minimum="-180"
                                Maximum="180"
                                Value="{Binding ShadowYaw.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderShadowYaw}"
                                 />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource Shadow_Pitch}" />
                        <Slider Grid.Row="2" Grid.Column="1"
                                x:Name="sliderShadowPitch"
                                Minimum="-90"
                                Maximum="90"
                                Value="{Binding ShadowPitch.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderShadowPitch}"
                                 />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{DynamicResource Shadow_DepthOffset}" />
                        <Slider Grid.Row="3" Grid.Column="1"
                                x:Name="sliderShadowDepthOffset"
                                Minimum="1"
                                Maximum="250"
                                Value="{Binding ShadowDepthOffset.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="3" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderShadowDepthOffset}"
                                 />

                    </Grid>

                    <CheckBox Margin="10,5,10,10"
                              Content="{DynamicResource Shadow_EnableSelfShadow}"
                              IsChecked="{Binding EnableSelfShadow.Value}"
                              />

                    <md:Card md:ShadowAssist.ShadowDepth="Depth1" 
                             Margin="5,10" 
                             Padding="0">
                        <Expander Header="{DynamicResource Shadow_FixedShadow_Header}"
                                  IsExpanded="False"
                                  >
                            <StackPanel IsEnabled="{Binding EnableShadow.Value}">

                                <CheckBox Margin="10,5"
                                          Content="{DynamicResource Shadow_FixedShadow_UseAlways}"
                                          IsChecked="{Binding EnableFixedShadowAlways.Value}"
                                          />
                                <CheckBox Margin="20,5,10,5"
                                          IsEnabled="{Binding EnableFixedShadowAlways.Value, Converter={StaticResource InvertBooleanConverter}}"
                                          Content="{DynamicResource Shadow_FixedShadow_UseOnLocomotion}"
                                          IsChecked="{Binding EnableFixedShadowWhenLocomotionActive.Value}"
                                          />
                            </StackPanel>
                        </Expander>


                    </md:Card>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">

                        <md:PackIcon Kind="WhiteBalanceIridescent"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource Bloom}"
                                   Margin="5"
                                   Style="{StaticResource HeaderText}"
                                   />
                        
                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetBloomSettingCommand}"
                                />
                    </StackPanel>

                    <Grid Margin="5">
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource Bloom_Color}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Rectangle Grid.Row="0" Grid.Column="1"
                                       Style="{StaticResource ColorSampleRectangle}">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{Binding BloomColor}"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Style="{DynamicResource ColorEditButton}"
                                    Command="{Binding EditBloomColorCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Style="{StaticResource ColorEditButtonIcon}"/>
                                    <TextBlock Style="{StaticResource ColorEditButtonText}"
                                               Text="{DynamicResource Setting_EditColor}"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource Bloom_Intensity}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderBloomIntensity"
                                Minimum="0"
                                Maximum="500"
                                Value="{Binding BloomIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderBloomIntensity}"
                                 />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{DynamicResource Bloom_Threshold}"
                               />
                        <Slider Grid.Row="2" Grid.Column="1"
                                x:Name="sliderBloomThreshold"
                                Minimum="0"
                                Maximum="500"
                                Value="{Binding BloomThreshold.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderBloomThreshold}"
                                 />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">

                        <md:PackIcon Kind="BabyFaceOutline"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource OutlineEffect}"
                                   Margin="5"
                                   Style="{StaticResource HeaderText}"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetOutlineEffectSettingCommand}"
                                />
                    </StackPanel>

                    <CheckBox Margin="10,5,10,5"
                              Content="{DynamicResource OutlineEffect_Enable}"
                              IsChecked="{Binding EnableOutlineEffect.Value}"
                              />

                    <Grid Margin="5">
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource OutlineEffect_Color}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Rectangle Grid.Row="0" Grid.Column="1"
                                   Style="{StaticResource ColorSampleRectangle}">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{Binding OutlineEffectColor}"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Style="{StaticResource ColorEditButton}"
                                    Command="{Binding EditOutlineEffectColorCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Style="{StaticResource ColorEditButtonIcon}"/>
                                    <TextBlock Style="{StaticResource ColorEditButtonText}"
                                               Text="{DynamicResource Setting_EditColor}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource OutlineEffect_Thickness}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderOutlineEffectThickness"
                                Minimum="1"
                                Maximum="150"
                                Value="{Binding OutlineEffectThickness.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderOutlineEffectThickness}"
                                 />

                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                  Margin="10,10,10,15"
                                  Content="{DynamicResource OutlineEffect_HighQualityMode}"
                                  IsChecked="{Binding OutlineEffectHighQualityMode.Value}"
                                  />

                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">

                        <md:PackIcon Kind="AlarmLightOutline"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource RimEffect}"
                                   Margin="5"
                                   Style="{StaticResource HeaderText}"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetRimSettingCommand}"
                                />
                    </StackPanel>

                    <CheckBox Margin="10,5,10,5"
                              Content="{DynamicResource RimEffect_Enable}"
                              IsChecked="{Binding RimEnabled.Value}"
                              />

                    <Grid Margin="5">
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                    Text="{DynamicResource RimEffect_Color}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Rectangle Style="{StaticResource ColorSampleRectangle}">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{Binding RimColor}"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Button Style="{StaticResource ColorEditButton}"
                                    Command="{Binding EditRimColorCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Style="{StaticResource ColorEditButtonIcon}"/>
                                    <TextBlock Style="{StaticResource ColorEditButtonText}"
                                               Text="{DynamicResource Setting_EditColor}"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource RimEffect_HdrColorIntensity}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderRimHdrColorIntensity"
                                Minimum="-10"
                                Maximum="100"
                                Value="{Binding RimHdrColorIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderRimHdrColorIntensity}"
                                 />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource RimEffect_Intensity}" />
                        <Slider Grid.Row="2" Grid.Column="1"
                                x:Name="sliderRimIntensity"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding RimIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderRimIntensity}"
                                 />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{DynamicResource RimEffect_Thickness}"
                               />
                        <Slider Grid.Row="3" Grid.Column="1"
                                x:Name="sliderRimThickness"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding RimThickness.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="3" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderRimThickness}"
                                 />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{DynamicResource RimEffect_Angle}"
                               />
                        <Slider Grid.Row="4" Grid.Column="1"
                                x:Name="sliderRimAngle"
                                Minimum="0"
                                Maximum="360"
                                Value="{Binding RimAngle.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="4" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderRimAngle}"
                                 />

                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="5">

                        <md:PackIcon Kind="Fan"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />

                        <TextBlock Text="{DynamicResource Wind}"
                                   Style="{StaticResource HeaderText}"
                                   Margin="5"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetWindSettingCommand}"
                                />
                    </StackPanel>

                    <CheckBox Margin="10,5,10,15"
                              Content="{DynamicResource Wind_Enable}"
                              IsChecked="{Binding EnableWind.Value}"
                              />

                    <Grid Margin="5"
                          IsEnabled="{Binding EnableWind.Value}"
                          >
                        <Grid.Resources>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource Wind_Strength}" />
                        <Slider Grid.Row="0" Grid.Column="1"
                                x:Name="sliderWindStrength"
                                Minimum="10"
                                Maximum="1000"
                                Value="{Binding WindStrength.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderWindStrength}"
                                 />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource Wind_Interval}" />
                        <Slider Grid.Row="1" Grid.Column="1"
                                x:Name="sliderWindInterval"
                                Minimum="10"
                                Maximum="500"
                                Value="{Binding WindInterval.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderWindInterval}"
                                 />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource Wind_Yaw}" />
                        <Slider Grid.Row="2" Grid.Column="1"
                                x:Name="sliderWindYaw"
                                Minimum="-180"
                                Maximum="180"
                                Value="{Binding WindYaw.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderWindYaw}"
                                 />

                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SideMarginSectionBorder}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Blur"
                                     Style="{StaticResource SettingHeaderPackIcon}"
                                     />
                        <TextBlock Text="{DynamicResource AO_Title}"
                                   Margin="5"
                                   Style="{StaticResource HeaderText}"
                                   />

                        <Button Style="{StaticResource CategorySettingResetButton}"
                                Command="{Binding ResetAmbientOcclusionSettingCommand}"
                                />
                    </StackPanel>

                    <CheckBox Content="{DynamicResource AO_Enable}"
                              IsChecked="{Binding EnableAmbientOcclusion.Value, Mode=TwoWay}"
                              />

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource AO_Intensity}" />
                        <Slider Grid.Column="1"
                                x:Name="sliderAmbientOcclusionIntensity"
                                Minimum="0"
                                Maximum="200"
                                Value="{Binding AmbientOcclusionIntensity.Value, Mode=TwoWay}"
                                />
                        <TextBox Grid.Column="2"
                                 Text="{Binding Value, ElementName=sliderAmbientOcclusionIntensity}"
                                 />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>

